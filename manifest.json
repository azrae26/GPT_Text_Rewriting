{
  "manifest_version": 3,
  "name": "AI 文章改寫助手",
  "version": "1.0",
  "description": "使用 AI 技術自動改寫文章",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "identity",
    "alarms",
    "downloads"
  ],
  "host_permissions": [
    "https://data.uanalyze.twobitto.com/*",
    "https://pro.uanalyze.com.tw/*",
    "https://mopsov.twse.com.tw/*",
    "https://www.googleapis.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://data.uanalyze.twobitto.com/*"
      ],
      "exclude_matches": [
        "https://data.uanalyze.twobitto.com/ai/assistants/create",
        "https://data.uanalyze.twobitto.com/ai/assistants/*/edit",
        "https://data.uanalyze.twobitto.com/gpt/summaries*"
      ],
      "js": [
        "default.js",
        "regex_helper/regex-helper.js",
        "text_highlight/highlight.js",
        "text_replace/manual-replace-manager.js",
        "text_replace/auto-replace-manager.js",
        "text_replace/replace-manager.js",
        "settings/settings-key.js",
        "settings/storage-manager.js",
        "settings/api-key-manager.js",
        "settings/model-manager.js",
        "settings/generation-manager.js",
        "settings/settings-cleanup.js",
        "settings/settings-classifier.js",
        "settings/settings-exporter.js",
        "settings/settings-importer.js",
        "settings/settings-loader.js",
        "status_monitor/status_monitor.js",
        "settings.js",
        "SettingsIO/settings-io.js",
        "SettingsIO/settings-io-startup.js",
        "notification.js",
        "undo.js",
        "text-processor.js",
        "translate/translate-config.js",
        "translate/translate-controller.js",
        "translate/translate-service.js",
        "translate/translate-adapter.js",
        "multiple_generation/multiple-generation.js",
        "google_translator/jwt-helper.js",
        "google_translator/google-translate.js",
        "stock_matcher/stock-matcher.js",
        "diff-highlighter/diff-highlighter.js",
        "ui-manager.js",
        "stock_report_helper/quick-copy.js",
        "stock_report_helper/stock-analyzer.js",
        "text_complete/auto-complete.js",
        "content.js"
      ],
      "css": ["content_script_uanalyze.css", "text_replace/replace.css"]
    },
    {
      "matches": [
        "https://crawler-api.uanalyze.com.tw/*"
      ],
      "css": ["content_script_uanalyze.css"]
    },
    {
      "matches": [
        "https://pro.uanalyze.com.tw/lab/*"
      ],
      "js": [
        "default.js",
        "settings/settings-key.js",
        "settings/storage-manager.js",
        "settings/api-key-manager.js",
        "settings/model-manager.js",
        "settings/generation-manager.js",
        "settings/settings-cleanup.js",
        "settings/settings-classifier.js",
        "settings/settings-exporter.js",
        "settings/settings-importer.js",
        "settings/settings-loader.js",
        "settings.js",
        "text-processor.js",
        "ua_assistant/auto-click.js",
        "ua_assistant/key-points-summary.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://pro.uanalyze.com.tw/lab/dashboard/lynch-tengrower/*"
      ],
      "js": [
        "default.js",
        "settings/settings-key.js",
        "settings/storage-manager.js",
        "settings/api-key-manager.js",
        "settings/model-manager.js",
        "settings/generation-manager.js",
        "settings/settings-cleanup.js",
        "settings/settings-classifier.js",
        "settings/settings-exporter.js",
        "settings/settings-importer.js",
        "settings/settings-loader.js",
        "settings.js",
        "stock_report_helper/quick-copy.js",
        "stock_report_helper/stock-analyzer.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["images/*"],
      "matches": ["https://pro.uanalyze.com.tw/*"]
    },
    {
      "resources": ["google_translator/gen-lang-client-0507957210-3b8a690087e2.json"],
      "matches": ["https://data.uanalyze.twobitto.com/*"]
    },
    {
      "resources": [
        "SettingsIO/settings-io.js",
        "SettingsIO/settings-io-startup.js",
        "SettingsIO/settings-io-popup.js", 
        "settings/settings-key.js", 
        "settings/settings-manager.js", 
        "settings/storage-manager.js",
        "settings/api-key-manager.js",
        "settings/model-manager.js",
        "settings/generation-manager.js",
        "settings/settings-cleanup.js",
        "settings/settings-classifier.js",
        "settings/settings-exporter.js",
        "settings/settings-importer.js",
        "settings/settings-loader.js",
        "settings/sync-status-manager.js",
        "settings.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16_blue.png",
      "48": "images/icon48_blue.png",
      "128": "images/icon128_blue.png"
    }
  },
  "icons": {
    "16": "images/icon16_blue.png",
    "48": "images/icon48_blue.png",
    "128": "images/icon128_blue.png"
  },
  "oauth2": {
    "client_id": "862665835661-leepued02022ei05bgb4jga850eglj0n.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "key": ""
}
