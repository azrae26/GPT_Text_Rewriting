{
  "rules": {
    "storage_management": {
      "description": "Chrome Extension Storage Management Guidelines",
      "enabled": true,
      "rules": [
        {
          "description": "Storage Type Selection",
          "guidelines": [
            "使用 chrome.storage.sync 儲存小型設定（如模型選擇、開關狀態等）",
            "使用 chrome.storage.local 儲存大型文本內容（如指令、背景知識等）",
            "當資料大小超過 8KB 時，考慮使用分塊儲存機制"
          ]
        },
        {
          "description": "Settings Group Management",
          "guidelines": [
            "為每個設定組合建立獨立儲存空間",
            "使用明確的命名規則（如 instructions_${groupName}）",
            "避免設定之間互相干擾"
          ]
        }
      ]
    },
    "settings_management": {
      "description": "設定管理架構指南",
      "enabled": true,
      "rules": [
        {
          "description": "檔案職責分離",
          "guidelines": [
            "核心設定邏輯統一在 settings.js 管理",
            "檔案操作相關邏輯在 settings-manager.js 處理",
            "UI 互動邏輯與核心邏輯分離"
          ]
        },
        {
          "description": "設定檔案格式",
          "guidelines": [
            "統一使用 SETTINGS_IDENTIFIER 進行檔案識別",
            "匯出檔案包含版本和應用程式識別",
            "設定分類存放並保持結構一致性"
          ]
        },
        {
          "description": "設計模式應用",
          "guidelines": [
            "使用單例模式管理全局設定",
            "使用策略模式處理不同類型設定"
          ]
        }
      ]
    },
    "error_handling": {
      "description": "錯誤處理和資料驗證",
      "enabled": true,
      "rules": [
        {
          "description": "Core Principles",
          "steps": [
            "檢查儲存操作的結果",
            "處理 chrome.runtime.lastError"
          ]
        }
      ]
    },
    "code_organization": {
      "description": "程式碼組織原則",
      "enabled": true,
      "rules": [
        {
          "description": "Key Practices",
          "guidelines": [
            "保持方法的單一職責",
            "使用私有方法封裝內部邏輯"
          ]
        }
      ]
    },
    "git_practices": {
      "description": "Git 推送最佳實踐",
      "enabled": true,
      "rules": [
        {
          "description": "提交訊息規範",
          "guidelines": [
            "使用簡短的標題（20字以內）描述主要變更",
            "使用 [類型] 前綴標示變更類型",
            "詳細說明使用編號列表，每點不超過5字"
          ]
        },
        {
          "description": "推送策略",
          "guidelines": [
            "推送前先執行 git pull 同步遠端更新",
            "確保本地分支與遠端分支名稱一致",
            "大型變更分多次小提交推送",
            "修改最後一次提交使用 --amend，然後 push -f"
          ]
        }
      ]
    }
  }
} 